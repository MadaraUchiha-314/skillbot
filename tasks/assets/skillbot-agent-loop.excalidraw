    {
      "id": "EP4q2tBNlnxrd8J9PsFvR",
      "type": "text",
      "x": 548.4970498833709,
      "y": 80.11481972206983,
      "width": 458.1241385611307,
      "height": 100,
      "angle": 0,
      "strokeColor": "#1e1e1e",
      "backgroundColor": "transparent",
      "fillStyle": "solid",
      "strokeWidth": 2,
      "strokeStyle": "solid",
      "roughness": 1,
      "opacity": 100,
      "groupIds": [],
      "frameId": null,
      "index": "aS",
      "roundness": null,
      "seed": 1587862602,
      "version": 387,
      "versionNonce": 401734346,
      "isDeleted": false,
      "boundElements": null,
      "updated": 1771829831653,
      "link": null,
      "locked": false,
      "text": "Since LLMs \"plan\" by suggesting tool calls,\nwhen a skill is loaded, all \"scripts\" for that\nskills are loaded as \"tools\" and bound to the\nLLM before invoke ",
      "fontSize": 20,
      "fontFamily": 5,
      "textAlign": "left",
      "verticalAlign": "top",
      "containerId": null,
      "originalText": "Since LLMs \"plan\" by suggesting tool calls, when a skill is loaded, all \"scripts\" for that skills are loaded as \"tools\" and bound to the LLM before invoke ",
      "autoResize": false,
      "lineHeight": 1.25
    },
    {
      "id": "e7Zh32KNHpORyt9tcsJYw",
      "type": "text",
      "x": 188.7051149696661,
      "y": 403.37340758812593,
      "width": 310.0622982094205,
      "height": 225,
      "angle": 0,
      "strokeColor": "#1e1e1e",
      "backgroundColor": "transparent",
      "fillStyle": "solid",
      "strokeWidth": 2,
      "strokeStyle": "solid",
      "roughness": 1,
      "opacity": 100,
      "groupIds": [],
      "frameId": null,
      "index": "aT",
      "roundness": null,
      "seed": 1088898518,
      "version": 844,
      "versionNonce": 667887702,
      "isDeleted": false,
      "boundElements": [],
      "updated": 1771832734665,
      "link": null,
      "locked": false,
      "text": "Finding a relevant skill can be\ndone using any search\ntechniques.\n\n- LLM call with all the skill name\nand descriptions loaded\n- Vector search\n- BM25\n",
      "fontSize": 20,
      "fontFamily": 5,
      "textAlign": "left",
      "verticalAlign": "top",
      "containerId": null,
      "originalText": "Finding a relevant skill can be done using any search techniques.\n\n- LLM call with all the skill name and descriptions loaded\n- Vector search\n- BM25\n",
      "autoResize": false,
      "lineHeight": 1.25
    },
